{
  "name": "@wisesama/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.local -- tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.mjs",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "sync": "dotenv -e .env.local -- tsx scripts/sync-phishing.ts",
    "backfill-identities": "dotenv -e .env.local -- tsx scripts/backfill-identities.ts",
    "make-admin": "dotenv -e .env.local -- tsx scripts/make-admin.ts",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@polkadot/api": "^15.8.1",
    "@polkadot/types": "^15.8.1",
    "@polkadot/util": "^13.4.3",
    "@polkadot/util-crypto": "^13.4.3",
    "@upstash/qstash": "^2.8.4",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.35.6",
    "@wisesama/database": "workspace:*",
    "@wisesama/types": "workspace:*",
    "@zig-zag/better-siwp": "^0.1.2",
    "better-auth": "^1.5.6",
    "dotenv": "^16.4.5",
    "fastest-levenshtein": "^1.0.16",
    "fastify": "^5.1.0",
    "fastify-better-auth": "^1.2.0",
    "fastify-raw-body": "^5.0.0",
    "resend": "^6.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.1",
    "@wisesama/config": "workspace:*",
    "dotenv-cli": "^7.4.4",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "5.6.3",
    "vitest": "^4.0.15"
  }
}
