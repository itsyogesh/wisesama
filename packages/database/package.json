{
  "name": "@wisesama/database",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "prisma generate",
    "dev": "prisma generate --watch",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:push": "dotenv -e ../../.env -- prisma generate && dotenv -e ../../.env -- prisma db push",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "clean": "rm -rf dist src/generated node_modules .turbo"
  },
  "devDependencies": {
    "@types/node": "^22.9.1",
    "@types/pg": "^8.20.0",
    "@wisesama/config": "workspace:*",
    "dotenv-cli": "^7.4.4",
    "prisma": "^7.6.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "5.6.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "pg": "^8.20.0"
  }
}
